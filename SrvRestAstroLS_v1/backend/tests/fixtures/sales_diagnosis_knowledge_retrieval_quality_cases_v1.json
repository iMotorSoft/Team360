    "changelog": [
      "v1: Initial 10 cases (Fase 1.7)",
      "v2: Added 5 new cases: explain_automation_basic, physical_task_car_wheel, tiktok_kpi_marketing, vague_automate_everything, manual_process_to_digital (Fase 1.8A)"
