    "frequency_volume": {"selected": ["daily", "medium_volume"]},
    "rules_clarity": {"selected": ["partially_clear"]},
    "human_dependency": {"selected": ["medium"]},
    "access_security": {"selected": ["password", "email_otp"]},
    "data_sensitivity": {"selected": ["personal_data"]},
    "expected_result": {"free_text": "Que el proceso quede automatizado y funcione sin intervencion manual."},
    "economic_impact": {"selected": ["medium"]}
