{
  "_meta": {
    "version": 1,
    "description": "Sales Diagnosis Knowledge Retrieval Quality evaluation cases for Fase 1.7",
    "created": "2026-06-15",
    "purpose": "Compare fake/in-memory vs knowledge_ingestion retrieval quality",
    "status": "dev/debug"
  },
  "default_answers": {
    "business_pain": {"free_text": "Quiero saber si se puede automatizar este proceso para ahorrar tiempo y evitar errores."},
    "systems_involved": {"selected": ["whatsapp", "email", "browser_portal"], "free_text": ""},
    "frequency_volume": {"selected": ["daily", "medium_volume"]},
    "rules_clarity": {"selected": ["partially_clear"]},
    "human_dependency": {"selected": ["medium"]},
    "access_security": {"selected": ["password", "email_otp"]},
    "data_sensitivity": {"selected": ["personal_data"]},
    "expected_result": {"free_text": "Que el proceso quede automatizado y funcione sin intervencion manual."},
    "economic_impact": {"selected": ["medium"]}
  },
  "default_visitor": {
    "source_channel": "home_public",
    "site_channel": "team360.live",
    "assistant_display_name": "Vera",
    "lead_owner": "team360_live",
    "service_code": "svc_sales_diagnosis",
    "package_code": "pkg_sales_diagnosis",
    "knowledge_scope_code": "ks_team360_sales_diagnosis"
  },
  "default_expectations": {
    "allow_fallback": false,
    "must_have_sources": true,
    "forbidden_claims": [
      "Step-to-Action",
      "lead_capture",
      "diagnostic_code activo",
      "WhatsApp handoff automático",
      "pricing garantizado",
      "ROI garantizado",
      "SLA garantizado",
      "bypass MFA",
      "bypass permisos"
    ],
    "must_have_scope": [
      "ks_team360_sales_diagnosis"
    ]
  },
  "cases": [
    {
      "case_id": "whatsapp_automation",
      "label": "WhatsApp automation",
      "question": "Quiero automatizar respuestas de WhatsApp para consultas frecuentes.",
      "overrides": {
        "systems_involved": {"selected": ["whatsapp"], "free_text": "WhatsApp Business"},
        "access_security": {"selected": ["password", "sms_otp"]}
      },
      "expectations": {
        "min_sources": 1,
        "expected_topics": ["whatsapp", "automation"],
        "requires_human_review": false
      }
    },
    {
      "case_id": "qr_diagnostic_code",
      "label": "QR / diagnostic_code",
      "question": "¿Puedo usar un QR para que el cliente empiece el diagnóstico?",
      "overrides": {
        "systems_involved": {"selected": ["whatsapp", "browser_portal"], "free_text": "QR codes"}
      },
      "expectations": {
        "min_sources": 1,
        "expected_topics": ["qr", "diagnostic_code"],
        "requires_human_review": false,
        "forbidden_claims": ["diagnostic_code activo"]
      }
    },
    {
      "case_id": "pricing_auto_quote",
      "label": "Pricing / auto-quote",
      "question": "¿El diagnóstico me puede dar precio automático o cotización cerrada?",
      "overrides": {
        "expected_result": {"free_text": "Obtener una cotizacion automatica sin hablar con un vendedor."}
      },
      "expectations": {
        "min_sources": 1,
        "expected_topics": ["pricing", "auto-quote"],
        "forbidden_claims": ["pricing garantizado", "SLA garantizado", "ROI garantizado"]
      }
    },
    {
      "case_id": "mfa_aprobacion_manual",
      "label": "MFA / aprobacion manual",
