---
import MarketingFooter from "../components/marketing/MarketingFooter.astro";
import MarketingHeader from "../components/marketing/MarketingHeader.astro";
import "../styles/global.css";
import "../styles/marketing.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  diagnosticHref?: string;
  headerCtaHref?: string;
  headerCtaLabel?: string;
  headerCtaMobileLabel?: string;
  footerDiagnosticHref?: string;
}

const {
  title = "Team360 | Automatización con IA para procesos reales",
  description = "Team360 ayuda a empresas a diagnosticar, implementar y medir automatizaciones con IA aplicadas a procesos reales de negocio.",
  canonical,
  diagnosticHref,
  headerCtaHref,
  headerCtaLabel,
  headerCtaMobileLabel,
  footerDiagnosticHref,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const resolvedHeaderCtaHref = headerCtaHref ?? diagnosticHref ?? "#vera";
const resolvedFooterDiagnosticHref = footerDiagnosticHref ?? diagnosticHref ?? "#contacto";
---

<!doctype html>
<html lang="es" data-theme="team360">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#102d4f" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Team360" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://team360.live/social/team360-social-preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Team360 automatiza tareas y procesos con inteligencia artificial y control humano" />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image:alt" content="Team360 automatiza tareas y procesos con inteligencia artificial y control humano" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://team360.live/social/team360-social-preview.png" />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#fbfcfa] text-[#203c55] antialiased">
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-[#102d4f] focus:shadow-lg" href="#contenido">
      Saltar al contenido
    </a>
    <MarketingHeader
      ctaHref={resolvedHeaderCtaHref}
      ctaLabel={headerCtaLabel}
      ctaMobileLabel={headerCtaMobileLabel}
    />
    <slot />
    <MarketingFooter diagnosticHref={resolvedFooterDiagnosticHref} />
  </body>
</html>
