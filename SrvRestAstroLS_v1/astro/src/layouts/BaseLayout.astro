---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Team360",
  description = "Base tecnica inicial del frontend Team360",
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="team360">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-200 text-base-content antialiased">
    <slot />
  </body>
</html>
