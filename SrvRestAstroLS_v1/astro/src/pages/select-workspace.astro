---
import { ROUTES } from "../components/global.js";
import { getMockProfiles } from "../lib/mock";
import { buildConsoleRoute } from "../lib/navigation/derive";
import MockAccessLayout from "../layouts/MockAccessLayout.astro";
import LinkButton from "../components/ui/LinkButton.astro";
import { Card } from "../components/ui";

const visibleProfiles = getMockProfiles().filter(({ id }) =>
  [
    "team360_admin",
    "team360_operator",
    "partner_admin",
    "client_admin",
  ].includes(id),
);
---

<MockAccessLayout
  title="Elegir experiencia mock | Team360 Console"
  description="Selector de perfiles y workspaces simulados para revisión de diseño."
>
  <section>
    <a
      class="text-base font-bold text-[#168b88] transition hover:text-[#102d4f] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#168b88]"
      href={ROUTES.login}
    >
      ← Volver al acceso mock
    </a>
    <p
      class="mt-7 text-base font-bold uppercase tracking-[0.2em] text-[#168b88]"
    >
      Selector para diseño
    </p>
    <h1
      class="mt-3 max-w-3xl text-4xl font-bold tracking-[-0.065em] text-[#102d4f] sm:text-6xl"
    >
      Elegí una experiencia operativa.
    </h1>
    <p class="mt-4 max-w-3xl text-xl leading-7 text-[#607587]">
      Cada acceso abre un perfil simulado con su workspace inicial. El selector
      interno permite recorrer contextos autorizados sin convertir esta maqueta
      en autenticación real.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        visibleProfiles.map((profile) => (
          <Card tag="section" variant="large">
            <p class="top-badge">{profile.label}</p>
            <p class="mt-3 flex-1 details-text">{profile.description}</p>
            <div class="mt-5 border-t border-[#edf1f2] pt-4">
              <LinkButton
                href={buildConsoleRoute(
                  profile.defaultWorkspaceId,
                  "home",
                  profile.id,
                )}
                size="large"
                variant="primary"
              >
                Abrir experiencia mock
              </LinkButton>
            </div>
          </Card>
          // </article>
        ))
      }
    </div>

    <p
      class="mt-7 rounded-2xl border border-[#dce8e8] bg-white/70 p-4 text-base leading-5 text-[#718793]"
    >
      Visibilidad frontend de diseño: ocultar una sección aquí no reemplaza
      autorización backend, membresías ni validación de permisos productivos.
    </p>
  </section>
</MockAccessLayout>
