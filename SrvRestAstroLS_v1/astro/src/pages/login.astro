---
import LinkButton from "../components/ui/LinkButton.astro";
import { ROUTES } from "../components/global.js";
import MockAccessLayout from "../layouts/MockAccessLayout.astro";
---

<MockAccessLayout
  title="Acceso de diseño | Team360 Console"
  description="Entrada mock para revisar Team360 Console sin autenticación real."
>
  <section class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#168b88]">Team360 Console</p>
      <h1 class="mt-4 max-w-2xl text-4xl font-bold tracking-[-0.065em] text-[#102d4f] sm:text-5xl">
        Acceso de diseño a la consola operativa.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-[#607587]">
        Esta entrada permite revisar perfiles y workspaces con datos simulados. No solicita credenciales, no valida usuarios y no representa el flujo de autenticación productivo.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <LinkButton href={ROUTES.selectWorkspace}>Elegir experiencia mock</LinkButton>
        <LinkButton href="/" variant="ghost" class="border border-[#d5e4e4] bg-white text-[#31536b]">Volver a la home</LinkButton>
      </div>
    </div>

    <aside class="rounded-[1.75rem] border border-[#dce8e8] bg-white p-6 shadow-[0_28px_70px_-56px_rgba(16,45,79,0.7)] sm:p-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#168b88]">Modo diseño</p>
      <h2 class="mt-3 text-xl font-bold tracking-[-0.04em] text-[#173b5b]">Sin autenticación real</h2>
      <ul class="mt-5 space-y-3 text-sm leading-6 text-[#607587]">
        <li class="rounded-xl bg-[#f3f8f8] px-3 py-2.5">Perfiles mock para Team360, partner y cliente final.</li>
        <li class="rounded-xl bg-[#f3f8f8] px-3 py-2.5">Workspaces sintéticos para validar navegación contextual.</li>
        <li class="rounded-xl bg-[#f3f8f8] px-3 py-2.5">Sin backend, sesiones, contraseñas ni operaciones reales.</li>
      </ul>
    </aside>
  </section>
</MockAccessLayout>
