---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmbedDiagnosticadorWrapper from "../lib/t360/diagnosticador/EmbedDiagnosticadorWrapper.svelte";

const DEMO_API_BASE_URL = "http://127.0.0.1:7050/api";
const DEMO_CLIENT_ID = "local_embed_demo";
const EXTERNAL_SESSION_STORAGE_KEY = "team360.embed.external.demo.session.v1";
---

<BaseLayout
  title="External Host Demo | Team360"
  description="Host externo controlado para validar el embed del Diagnosticador Team360"
>
  <main class="external-host-demo" data-testid="external-host-demo">
    <section class="host-shell">
      <header class="host-header" data-testid="external-host-header">
        <p class="host-eyebrow">External Host Demo</p>
        <h1>Host externo controlado para el Diagnosticador</h1>
        <p class="host-copy">
          Esta página simula un sitio anfitrión separado que monta el embed con
          `client_id`, auth server-side y sesión aislada.
        </p>
      </header>

      <div class="host-grid">
        <aside class="host-notes" data-testid="external-host-notes">
          <h2>Contrato público mínimo</h2>
          <ul>
            <li><strong>clientId</strong>: identificador público del embed.</li>
            <li><strong>apiBaseUrl</strong>: endpoint público del backend.</li>
            <li><strong>sessionStorageKey</strong>: namespace aislado por host.</li>
            <li><strong>assistantName</strong> y <strong>compact</strong>: solo visual.</li>
          </ul>
          <p>
            El host no conoce tenant, scope ni secretos. La firma por turno se
            obtiene vía <code>/api/diagnosis/embed/auth</code>.
          </p>
        </aside>

        <div class="embed-slot" data-testid="external-host-embed-slot">
          <EmbedDiagnosticadorWrapper
            client:load
            apiBaseUrl={DEMO_API_BASE_URL}
            clientId={DEMO_CLIENT_ID}
            assistantName="Vera / Diagnosticador Team360"
            compact={true}
            sessionStorageKey={EXTERNAL_SESSION_STORAGE_KEY}
          />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .external-host-demo {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(24, 119, 242, 0.14), transparent 28rem),
      linear-gradient(180deg, #f4f7fb 0%, #edf2f8 100%);
    padding: 2rem 1rem 3rem;
  }

  .host-shell {
    margin: 0 auto;
    max-width: 78rem;
  }

  .host-header {
    margin-bottom: 1.5rem;
  }

  .host-eyebrow {
    margin-bottom: 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1d4ed8;
  }

  .host-header h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.05;
    color: #11263f;
  }

  .host-copy {
    margin-top: 0.75rem;
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: #4a627a;
  }

  .host-grid {
    display: grid;
    gap: 1.25rem;
    align-items: start;
  }

  .host-notes,
  .embed-slot {
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
  }

  .host-notes {
    padding: 1.5rem;
    color: #24364a;
  }

  .host-notes h2 {
    margin: 0 0 0.85rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #102d4f;
  }

  .host-notes ul {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    line-height: 1.55;
  }

  .host-notes p {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.6;
    color: #5a7086;
  }

  .host-notes code {
    font-size: 0.9em;
  }

  .embed-slot {
    padding: 1rem 0.5rem;
  }

  @media (min-width: 960px) {
    .host-grid {
      grid-template-columns: minmax(18rem, 24rem) minmax(0, 1fr);
    }

    .embed-slot {
      padding: 1.25rem 0.75rem;
    }
  }
</style>
