---
const stages = [
  {
    title: "Diagnóstico claro",
    detail: "Procesos y prioridades",
    status: "01",
  },
  {
    title: "Implementación gradual",
    detail: "Automatización con control",
    status: "02",
  },
  { title: "Seguimiento medible", detail: "Tableros y reportes", status: "03" },
];
---

<div
  class="relative mx-auto w-full max-w-[560px] lg:mr-0"
  aria-label="Recorrido Team360: diagnóstico, implementación y seguimiento"
>
  <div class="absolute -inset-12 -z-10 rounded-full bg-[#6ed7cb]/15 blur-3xl">
  </div>
  <div
    class="overflow-hidden rounded-[2rem] border border-white/80 bg-white/82 p-4 shadow-[0_30px_80px_-34px_rgba(16,45,79,0.35)] backdrop-blur sm:p-5"
  >
    <div
      class="flex items-center justify-between border-b border-[#e6edf0] px-1 pb-4"
    >
      <div>
        <p class="top-badge">Ruta de mejora</p>
        <p class="mt-1 text-sm font-semibold text-[#102d4f]">
          Un proceso ordenado, etapa por etapa
        </p>
      </div>
      <span
        class="inline-flex items-center gap-2 rounded-full bg-[#e7f8f5] px-3 py-1.5 text-xs font-semibold text-[#157773]"
      >
        <span class="size-2 rounded-full bg-[#24aa9f]"></span>
        Acompañado
      </span>
    </div>

    <div class="mt-5 space-y-3">
      {
        stages.map((stage, index) => (
          <div
            class:list={[
              "group rounded-2xl border p-4 transition",
              index === 1
                ? "border-[#b7e3de] bg-[#f0fbf9]"
                : "border-[#e2e9ed] bg-white",
            ]}
          >
            <div class="flex items-center gap-4">
              <span
                class:list={[
                  "grid size-11 shrink-0 place-items-center rounded-xl text-xs font-bold",
                  index === 1
                    ? "bg-[#168b88] text-white"
                    : "bg-[#eef3f6] text-[#4d667c]",
                ]}
              >
                {stage.status}
              </span>
              <div class="min-w-0 flex-1">
                <p class="font-semibold tracking-[-0.02em] text-[#173b5b]">
                  {stage.title}
                </p>
                <p class="mt-0.5 text-sm text-[#70808e]">{stage.detail}</p>
              </div>
              <span
                class:list={[
                  "size-2.5 rounded-full",
                  index === 1 ? "bg-[#28b1a5]" : "bg-[#cbd8de]",
                ]}
              />
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3">
      <div class="rounded-2xl bg-[#102d4f] p-4 text-white">
        <p
          class="text-xs font-semibold uppercase tracking-[0.14em] text-white/55"
        >
          Enfoque
        </p>
        <p class="mt-3 text-base font-semibold">Procesos reales</p>
        <p class="mt-1 text-xs leading-5 text-white/65">
          Prioridades comprensibles para el equipo.
        </p>
      </div>
      <div class="rounded-2xl bg-[#eaf4f6] p-4">
        <p
          class="text-xs font-semibold uppercase tracking-[0.14em] text-[#648090]"
        >
          Resultado
        </p>
        <p class="mt-3 text-base font-semibold text-[#153854]">Visibilidad</p>
        <p class="mt-1 text-xs leading-5 text-[#658091]">
          Seguimiento con tableros y reportes.
        </p>
      </div>
    </div>
  </div>

  <div
    class="absolute -bottom-5 -left-3 flex items-center gap-3 rounded-2xl border border-white/75 bg-white/90 px-4 py-3 shadow-[0_18px_40px_-24px_rgba(16,45,79,0.5)] backdrop-blur sm:-left-8"
  >
    <span
      class="grid size-9 place-items-center rounded-xl bg-[#e6f8f5] text-[#168b88]"
      aria-hidden="true"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path d="m5 12 4 4L19 6" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    </span>
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#7b8b98]">
        Principio Team360
      </p>
      <p class="text-sm font-semibold text-[#173b5b]">
        Automatizar lo que sí conviene
      </p>
    </div>
  </div>
</div>
