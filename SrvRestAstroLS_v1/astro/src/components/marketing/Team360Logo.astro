---
interface Props {
    compact?: boolean;
    inverted?: boolean;
    showIcon?: boolean;
    logoSrc?: string;
    size?: "small" | "medium" | "large" | string;
}

const {
    compact = false,
    inverted = false,
    showIcon = true,
    logoSrc = "/src/assets/team360_logo_t.png",
    size = "medium",
} = Astro.props;

const sizeClasses = {
    small: "size-12",
    medium: "size-18",
    large: "size-20",
};

const finalSizeClass = sizeClasses[size as keyof typeof sizeClasses] || size;
---

<a
    href="/"
    class="inline-flex items-center gap-3"
    aria-label="Team360, inicio"
    translate="no"
>
    {
        showIcon && (
            <span
                class:list={[
                    finalSizeClass,
                    "bg-contain bg-no-repeat bg-center",
                ]}
                style={`background-image: url('${logoSrc}');`}
            />
        )
    }
    <span
        class:list={[
            "font-semibold tracking-[-0.04em]",
            inverted ? "text-white/85" : "text-[#102d4f]",
        ]}
    >
        <span class="text-2xl md:text-3xl font-poppins">Team</span><span
            class="text-2xl md:text-3xl text-[#168b88] font-poppins">360</span
        >
        {
            !compact && (
                <span
                    class:list={[
                        "ml-2 hidden text-sm font-medium tracking-[0.12em] sm:inline",
                        inverted ? "text-white/60" : "text-[#62758a]",
                    ]}
                >
                    OPERACIONES INTELIGENTES
                </span>
            )
        }
    </span>
</a>
