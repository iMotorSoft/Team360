---
import LinkButton from "../ui/LinkButton.astro";
import Team360Logo from "./Team360Logo.astro";
// import BrandMark from "./BrandMark.astro";
import { CONSOLE_SITE_URL } from "../global.js";

interface Props {
  ctaHref?: string;
  ctaLabel?: string;
  ctaMobileLabel?: string;
}

const {
  ctaHref = "#vera",
  ctaLabel = "Hablar con Vera",
  ctaMobileLabel = ctaLabel,
} = Astro.props;
---

<header
  class="sticky top-0 z-50 border-b border-[#dce6eb]/75 bg-[#fbfcfa]/90 backdrop-blur-xl"
>
  <div
    class="mx-auto flex max-w-8xl items-center justify-between md:justify-around gap-6 px-5 py-2.5 sm:py-4 sm:px-8 lg:px-10"
  >
    <Team360Logo compact size="size-12 md:size-18" />

    <nav
      class="hidden items-center gap-8 text-lg font-medium text-[#526579] lg:flex"
      aria-label="Navegación principal"
    >
      <a class="transition hover:text-[#102d4f]" href="#solucion">Qué hacemos</a
      >
      <a class="transition hover:text-[#102d4f]" href="#casos">Casos de uso</a>
      <a class="transition hover:text-[#102d4f]" href="#metodo"
        >Nuestro método</a
      >
      <a class="transition hover:text-[#102d4f]" href="#partners">Partners</a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-5">
      <!-- {`${CONSOLE_SITE_URL}/login`} -->
      <a
        class="hidden text-sm font-semibold text-[#39536b] transition hover:text-[#102d4f] sm:inline sm:text-lg"
        href="/login"
      >
        Acceso clientes
      </a>
      <LinkButton
        href={ctaHref}
        size="default"
        class="btn-sm md:btn-lg text-xs sm:px-8 sm:text-lg"
      >
        <span class="sm:hidden">{ctaMobileLabel}</span>
        <span class="hidden sm:inline">{ctaLabel}</span>
      </LinkButton>
    </div>
  </div>
</header>
